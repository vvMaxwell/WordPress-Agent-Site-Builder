{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/themify-site-spec.schema.json",
  "title": "Themify Site Builder Site Spec",
  "type": "object",
  "required": ["version", "site", "pages"],
  "properties": {
    "version": {"type": "string"},
    "site": {
      "type": "object",
      "required": ["name"],
      "properties": {
        "name": {"type": "string"},
        "tagline": {"type": "string"},
        "url": {"type": "string"},
        "locale": {"type": "string"},
        "timezone": {"type": "string"}
      },
      "additionalProperties": true
    },
    "style": {
      "type": "object",
      "properties": {
        "accentColor": {"type": "string"},
        "secondaryColor": {"type": "string"},
        "neutralColor": {"type": "string"},
        "fontIntent": {"type": "string"},
        "roundedCorners": {"type": "string"}
      },
      "additionalProperties": true
    },
    "navigation": {
      "type": "object",
      "properties": {
        "primary": {
          "type": "array",
          "items": {"type": "string"}
        },
        "footer": {
          "type": "array",
          "items": {"type": "string"}
        }
      },
      "additionalProperties": true
    },
    "pages": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/page"}
    },
    "forms": {
      "type": "array",
      "items": {"type": "object"}
    },
    "reusableSections": {
      "type": "array",
      "items": {"$ref": "#/$defs/section"}
    }
  },
  "$defs": {
    "page": {
      "type": "object",
      "required": ["slug", "title", "sections"],
      "properties": {
        "slug": {"type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"},
        "title": {"type": "string"},
        "templateIntent": {"type": "string"},
        "seo": {
          "type": "object",
          "properties": {
            "title": {"type": "string"},
            "description": {"type": "string"}
          },
          "additionalProperties": true
        },
        "sections": {
          "type": "array",
          "items": {"$ref": "#/$defs/section"}
        }
      },
      "additionalProperties": true
    },
    "section": {
      "type": "object",
      "required": ["type"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["hero", "text", "services", "cta", "faq", "testimonials", "form"]
        },
        "slug": {"type": "string"},
        "title": {"type": "string"},
        "heading": {"type": "string"},
        "body": {"type": "string"},
        "items": {
          "type": "array",
          "items": {"type": "object"}
        },
        "primaryAction": {
          "type": "object",
          "properties": {
            "label": {"type": "string"},
            "href": {"type": "string"}
          },
          "additionalProperties": true
        },
        "media": {
          "type": "object",
          "properties": {
            "intent": {"type": "string"},
            "alt": {"type": "string"},
            "attachmentId": {"type": "integer"}
          },
          "additionalProperties": true
        },
        "form": {"type": "object"}
      },
      "additionalProperties": true
    }
  }
}
